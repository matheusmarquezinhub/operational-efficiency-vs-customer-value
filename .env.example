# Credenciais locais para conexão com SQL Server.
# Mantenha segredos reais apenas no arquivo .env, que já está ignorado pelo Git.
# Use DB_TRUSTED_CONNECTION=yes para autenticação integrada do Windows.

DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=SEU_SERVIDOR_SQL
DB_DATABASE=SEU_BANCO_DE_DADOS
DB_TRUSTED_CONNECTION=no
DB_USER=SEU_USUARIO
DB_PASSWORD=SUA_SENHA
TRUST_CERT=yes
